# Shared
NODE_ENV=development

# API service (Railway service root: apps/api)
PORT=4000
API_URL=http://localhost:4000
WEB_ORIGIN=http://localhost:3000
MONGODB_URI=mongodb://localhost:27017/marketplace
JWT_ACCESS_SECRET=replace-with-at-least-64-random-characters-access-secret
JWT_REFRESH_SECRET=replace-with-at-least-64-random-characters-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
COOKIE_DOMAIN=localhost

# Web service (Railway service root: apps/web)
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
